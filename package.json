{
  "name": "cliuno-adonisjs-template",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "author": "ru44",
  "license": "AGPL-3.0-only",
  "keywords": [
    "cliuno",
    "adonisjs",
    "typescript",
    "javascript"
  ],
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt app/ start/ database/ config/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@swc/core": "1.15.43",
    "@types/luxon": "^3.7.2",
    "@types/node": "^26.1.1",
    "hot-hook": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.5",
    "ts-node-maintained": "^10.9.6",
    "typescript": "~7.0.2",
    "oxlint": "^1.74.0",
    "oxfmt": "^0.59.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/core": "^7.3.5",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^22.4.2",
    "@vinejs/vine": "^4.4.0",
    "better-sqlite3": "^12.11.1",
    "luxon": "^3.7.2",
    "reflect-metadata": "^0.2.2",
    "otpauth": "^9.5.0",
    "hi-base32": "^0.5.1"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "overrides": {
    "strtok3": "8.0.1"
  },
  "resolutions": {
    "strtok3": "8.0.1"
  }
}
